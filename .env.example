# ==============================================================================
# GESTMONEY - Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ==============================================================================

# ------------------------------------------------------------------------------
# APPLICATION
# ------------------------------------------------------------------------------
NODE_ENV=development
APP_NAME=GESTMONEY
APP_VERSION=1.0.0

# ------------------------------------------------------------------------------
# API BACKEND (NestJS)
# ------------------------------------------------------------------------------
API_PORT=3001
API_HOST=0.0.0.0
API_PREFIX=api/v1

# ------------------------------------------------------------------------------
# FRONTEND (Next.js)
# ------------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GESTMONEY

# ------------------------------------------------------------------------------
# BASE DE DONNÉES (PostgreSQL)
# ------------------------------------------------------------------------------
DATABASE_URL=postgresql://gestmoney_user:gestmoney_pass@localhost:5432/gestmoney_db?schema=public
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=gestmoney_db
DATABASE_USER=gestmoney_user
DATABASE_PASSWORD=gestmoney_pass
DATABASE_SSL=false
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# ------------------------------------------------------------------------------
# REDIS (Cache & Queue)
# ------------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600

# ------------------------------------------------------------------------------
# ELASTICSEARCH
# ------------------------------------------------------------------------------
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
ELASTICSEARCH_INDEX_PREFIX=gestmoney_

# ------------------------------------------------------------------------------
# AUTHENTIFICATION JWT
# ------------------------------------------------------------------------------
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d

# ------------------------------------------------------------------------------
# CHIFFREMENT
# ------------------------------------------------------------------------------
ENCRYPTION_KEY=your-32-character-encryption-key!!
ENCRYPTION_IV=your-16-char-iv!!

# ------------------------------------------------------------------------------
# MOBILE MONEY - ORANGE MONEY
# ------------------------------------------------------------------------------
ORANGE_MONEY_API_URL=https://api.orange.com/orange-money-webpay
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_CALLBACK_URL=http://localhost:3001/api/v1/webhooks/orange-money

# ------------------------------------------------------------------------------
# MOBILE MONEY - MTN MOMO
# ------------------------------------------------------------------------------
MTN_MOMO_API_URL=https://sandbox.momodeveloper.mtn.com
MTN_MOMO_SUBSCRIPTION_KEY=
MTN_MOMO_API_USER=
MTN_MOMO_API_KEY=
MTN_MOMO_ENVIRONMENT=sandbox
MTN_MOMO_CALLBACK_URL=http://localhost:3001/api/v1/webhooks/mtn-momo

# ------------------------------------------------------------------------------
# MOBILE MONEY - WAVE
# ------------------------------------------------------------------------------
WAVE_API_URL=https://api.wave.com/v1
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=
WAVE_CALLBACK_URL=http://localhost:3001/api/v1/webhooks/wave

# ------------------------------------------------------------------------------
# MOBILE MONEY - MOOV MONEY
# ------------------------------------------------------------------------------
MOOV_MONEY_API_URL=
MOOV_MONEY_API_KEY=
MOOV_MONEY_MERCHANT_ID=

# ------------------------------------------------------------------------------
# EMAIL (SMTP)
# ------------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@gestmoney.com
SMTP_PASSWORD=
EMAIL_FROM=GESTMONEY <noreply@gestmoney.com>

# ------------------------------------------------------------------------------
# SMS
# ------------------------------------------------------------------------------
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+1234567890

# ------------------------------------------------------------------------------
# STOCKAGE FICHIERS (S3 / MinIO)
# ------------------------------------------------------------------------------
STORAGE_DRIVER=minio
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=gestmoney

# AWS S3 (si STORAGE_DRIVER=s3)
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=gestmoney-prod

# ------------------------------------------------------------------------------
# MONITORING & LOGGING
# ------------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=json
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ------------------------------------------------------------------------------
# RATE LIMITING
# ------------------------------------------------------------------------------
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ------------------------------------------------------------------------------
# CORS
# ------------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ------------------------------------------------------------------------------
# MULTI-TENANT
# ------------------------------------------------------------------------------
DEFAULT_TENANT_ID=default
SUPER_ADMIN_EMAIL=admin@gestmoney.com
SUPER_ADMIN_PASSWORD=Admin@123456!

# ------------------------------------------------------------------------------
# WEBSOCKET
# ------------------------------------------------------------------------------
WS_PORT=3002

# ------------------------------------------------------------------------------
# QUEUE (Bull / BullMQ)
# ------------------------------------------------------------------------------
QUEUE_REDIS_URL=redis://localhost:6379/1

# ------------------------------------------------------------------------------
# ML / IA (Détection fraude)
# ------------------------------------------------------------------------------
ML_SERVICE_URL=http://localhost:8000
ML_API_KEY=

# ------------------------------------------------------------------------------
# IA - SARA (Assistant GESTMONEY)
# ------------------------------------------------------------------------------
# Fournisseur IA actif : groq | openai | anthropic
SARA_PROVIDER=groq
SARA_MODEL=llama-3.3-70b-versatile
SARA_TEMPERATURE=0.7
SARA_MAX_TOKENS=2048
SARA_QUOTA_JOURNALIER=10000
SARA_QUOTA_MENSUEL=300000

# Groq (recommandé — rapide et gratuit)
GROQ_API_KEY=

# OpenAI (fallback)
OPENAI_API_KEY=

# Anthropic (fallback)
ANTHROPIC_API_KEY=

# ------------------------------------------------------------------------------
# PAIEMENTS SAAS (abonnements GESTMONEY)
# ------------------------------------------------------------------------------
# CinetPay (Afrique de l'Ouest)
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_NOTIFY_URL=https://gestmoney.ibigsoft.com/api/webhooks/cinetpay

# Stripe (international)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ------------------------------------------------------------------------------
# DÉMO (accès démo sécurisé — ne jamais exposer côté client)
# ------------------------------------------------------------------------------
DEMO_EMAIL=demo@gestmoney.ibigsoft.com
DEMO_PASSWORD=

# ------------------------------------------------------------------------------
# DOCKER (pour docker-compose)
# ------------------------------------------------------------------------------
POSTGRES_DB=gestmoney_db
POSTGRES_USER=gestmoney_user
POSTGRES_PASSWORD=gestmoney_pass
