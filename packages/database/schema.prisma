  SALON
  COLD_CALL
  EMAIL_CAMPAGNE
  AUTRE
}

enum ProspectPriorite {
  BASSE
  NORMALE
  HAUTE
  CRITIQUE
}

enum ProspectStatut {
  NOUVEAU
  A_CONTACTER
  CONTACTE
  QUALIFIE
  DEMO_PREVUE
  DEMO_REALISEE
  OFFRE_ENVOYEE
  NEGOCIATION
  GAGNE
  PERDU
  A_RELANCER
}

// ==============================================================================
// DÉMONSTRATIONS
// ==============================================================================

model Demonstration {
  id            String     @id @default(cuid())
  prospectId    String?
  entreprise    String
  logiciel      String     @default("GESTMONEY")
  date          DateTime
  fuseau        String     @default("Africa/Abidjan")
  mode          DemoMode   @default(VISIO)
  lienVisio     String?
  agentId       String?
  besoins       String?
  notes         String?
  statut        DemoStatut @default(PLANIFIEE)
  compteRendu   String?
  prochainerEtape String?
  rappelEnvoye  Boolean    @default(false)
  confirme      Boolean    @default(false)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  prospect      Prospect?  @relation(fields: [prospectId], references: [id])
  offres        Offre[]

  @@index([date])
  @@index([statut])
  @@map("demonstrations")
}

enum DemoMode {
  VISIO
  PRESENTIEL
  TELEPHONE
  ENREGISTREMENT
}

enum DemoStatut {
  PLANIFIEE
  CONFIRMEE
  REALISEE
  ANNULEE
  REPORTEE
  NO_SHOW
}

// ==============================================================================
// OFFRES PERSONNALISÉES
// ==============================================================================

model Offre {
  id              String      @id @default(cuid())
  reference       String      @unique
  prospectId      String?
  entreprise      String
  logiciel        String      @default("GESTMONEY")
  formule         String?
  modules         Json        @default("[]")
  nbUtilisateurs  Int         @default(1)
  nbSites         Int         @default(1)
  dureesMois      Int         @default(12)
  devise          String      @default("XOF")
  prixHT          Decimal     @db.Decimal(15, 2)
  remise          Decimal     @default(0) @db.Decimal(5, 2)
  taxes           Decimal     @default(0) @db.Decimal(5, 2)
  prixTTC         Decimal     @db.Decimal(15, 2)
  options         Json        @default("{}")
  formation       Boolean     @default(false)
  migration       Boolean     @default(false)
  accompagnement  Boolean     @default(false)
  validiteJours   Int         @default(30)
  conditions      String?
  statut          OffreStatut @default(BROUILLON)
  signeeAt        DateTime?
  accepteeAt      DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  prospect        Prospect?       @relation(fields: [prospectId], references: [id])
  demonstration   Demonstration?  @relation(fields: [demonstrationId], references: [id])
  demonstrationId String?
  licenceEvents   LicenceEvent[]

  @@index([statut])
  @@index([createdAt])
  @@map("offres")
}

enum OffreStatut {
  BROUILLON
  ENVOYEE
  CONSULTEE
  ACCEPTEE
  REFUSEE
  EXPIREE
  CONVERTIE
}

// ==============================================================================
// MOTEUR DE LICENCES
// ==============================================================================

model LicenceEvent {
  id          String            @id @default(cuid())
  tenantId    String?
  offreId     String?
  type        LicenceEventType
  plan        String?
  montant     Decimal?          @db.Decimal(15, 2)
  devise      String?
  dateDebut   DateTime?
  dateFin     DateTime?
  periodeGrace DateTime?
  motif       String?
  agentId     String?
  createdAt   DateTime          @default(now())

  offre       Offre?            @relation(fields: [offreId], references: [id])

  @@index([tenantId])
  @@index([type])
  @@index([createdAt])
  @@map("licence_events")
}

enum LicenceEventType {
  ESSAI_ACTIVE
  ABONNEMENT_ACTIVE
  ABONNEMENT_RENOUVELE
  ABONNEMENT_UPGRAYE
  ABONNEMENT_DEGRADE
  ABONNEMENT_SUSPENDU
  ABONNEMENT_EXPIRE
  ABONNEMENT_REACTIVE
  PERIODE_GRACE_ACTIVEE
  COUPON_APPLIQUE
  REMBOURSEMENT
}

// ==============================================================================
// PAIEMENTS
// ==============================================================================

model Paiement {
  id              String          @id @default(cuid())
  tenantId        String?
  reference       String          @unique
  montant         Decimal         @db.Decimal(15, 2)
  devise          String          @default("XOF")
  provider        PaymentProvider
  providerRef     String?
  statut          PaiementStatut  @default(EN_ATTENTE)
  metadata        Json            @default("{}")
  webhookPayload  Json?
  validePar       String?
  valideAt        DateTime?
  rembourseAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([tenantId])
  @@index([statut])
  @@index([provider])
  @@index([createdAt])
  @@map("paiements")
}

enum PaymentProvider {
  CINETPAY
  MONEROO
  FEDAPAY
  PAYSTACK
  FLUTTERWAVE
  STRIPE
  MOBILE_MONEY
  VIREMENT
  ESPECES
  MANUEL
}

enum PaiementStatut {
  EN_ATTENTE
  EN_COURS
  REUSSI
  ECHOUE
  REMBOURSE
  ANNULE
  EXPIRE
}

/// Configuration d'un moyen de paiement. RIEN n'est codé en dur : clés,
/// numéros de réception, coordonnées bancaires et adresses de wallet vivent
/// ici et sont modifiables depuis l'administration, sans redéploiement.
/// `secrets` ne doit JAMAIS être renvoyé tel quel au client — voir
/// PaymentConfigService, qui le masque.
model PaymentMethodConfig {
  id            String        @id @default(cuid())
  /// null = configuration globale de la plateforme
  tenantId      String?
  methode       PaymentMethod
  /// Discrimine les variantes d'une même méthode : ORANGE_MONEY, MTN, WAVE,
  /// USDT_TRC20, WESTERN_UNION… Vide pour les méthodes sans variante.
  variante      String        @default("")
  libelle       String
  actif         Boolean       @default(false)
  /// Mode bac à sable des passerelles électroniques
  sandbox       Boolean       @default(true)
  /// Données NON sensibles, affichables au client : numéro de réception,
  /// titulaire, IBAN, BIC, adresse de wallet, réseau, instructions…
  parametres    Json          @default("{}")
  /// Clés secrètes (API key, secret, webhook secret). Chiffré au repos.
  secrets       Json          @default("{}")
  /// Restrictions : [] = aucune restriction
  paysAutorises String[]      @default([])
  plansAutorises String[]     @default([])
  devises       String[]      @default([])
  ordreAffichage Int          @default(0)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([tenantId, methode, variante])
  @@index([actif])
  @@map("payment_method_configs")
}

enum PaymentMethod {
  MOBILE_MONEY_MANUEL
  PASSERELLE
  VIREMENT_NATIONAL
  VIREMENT_INTERNATIONAL
  TRANSFERT_ARGENT
  ESPECES_AGENCE
  CHEQUE
  CRYPTO
  VOUCHER
  PAIEMENT_LIVRAISON
}

/// Journal des modifications de configuration : qui a changé quoi et quand.
model PaymentConfigAudit {
  id         String   @id @default(cuid())
  configId   String
  userId     String?
  champ      String
  ancienneValeur String?
  nouvelleValeur String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([configId])
  @@index([createdAt])
  @@map("payment_config_audits")
}

/// Preuve de paiement téléversée par le client (capture Mobile Money,
/// bordereau de virement, MTCN, hash de transaction crypto…).
/// Stockée hors de /public — jamais servie en statique.
model PaymentProof {
  id           String       @id @default(cuid())
  paiementId   String
  /// Chemin dans le stockage privé
  cheminFichier String?
  nomOriginal  String?
  mimeType     String?
  tailleOctets Int?
  /// SHA256 du fichier : permet de détecter une preuve déjà soumise ailleurs
  hashSha256   String?
  /// Référence textuelle : MTCN, numéro de chèque, hash blockchain, code reçu
  referenceTexte String?
  statut       ProofStatut  @default(EN_ATTENTE)
  motifRejet   String?
  revuPar      String?
  revuAt       DateTime?
  createdAt    DateTime     @default(now())

  @@index([paiementId])
  @@index([hashSha256])
  @@index([statut])
  @@map("payment_proofs")
}

enum ProofStatut {
  EN_ATTENTE
  VALIDEE
  REJETEE
}

/// Idempotence des webhooks : un même événement ne peut activer qu'une fois.
/// La contrainte d'unicité est la garantie — pas un test applicatif, qui
/// laisserait passer deux webhooks simultanés.
model WebhookEvent {
  id           String   @id @default(cuid())
  provider     String
  /// Identifiant fourni par la passerelle
  eventId      String
  signature    String?
  payload      Json
  traite       Boolean  @default(false)
  traiteAt     DateTime?
  erreur       String?
  createdAt    DateTime @default(now())

  @@unique([provider, eventId])
  @@index([traite])
  @@map("webhook_events")
}

/// Codes prépayés vendus par des revendeurs agréés. Usage unique.
model Voucher {
  id          String        @id @default(cuid())
  tenantId    String?
  /// Stocké en clair pour la recherche, mais généré aléatoirement (non devinable)
  code        String        @unique
  lot         String?
  plan        String?
  valeur      Decimal       @db.Decimal(15, 2)
  devise      String        @default("XOF")
  /// Durée d'abonnement accordée à l'utilisation
  dureeJours  Int           @default(30)
  statut      VoucherStatut @default(DISPONIBLE)
  utilisePar  String?
  utiliseAt   DateTime?
  expireAt    DateTime?
  createdAt   DateTime      @default(now())

  @@index([statut])
  @@index([lot])
  @@map("vouchers")
}

enum VoucherStatut {
  DISPONIBLE
  UTILISE
  EXPIRE
  ANNULE
}

// ==============================================================================
// SARA — ASSISTANT IA
// ==============================================================================

model SaraConversation {
  id          String        @id @default(cuid())
  tenantId    String?
  userId      String?
  sessionId   String
  context     String        @default("PUBLIC") // PUBLIC | INTERNE | SUPPORT
  messages    Json          @default("[]")
  prospect    Json?
  totalTokens Int           @default(0)
  provider    String        @default("groq")
  modele      String        @default("llama-3.3-70b-versatile")
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([tenantId])
  @@index([sessionId])
  @@index([createdAt])
  @@map("sara_conversations")
}

model SaraConfig {
  id              String   @id @default(cuid())
  tenantId        String?  @unique // null = config globale IBIG Soft
  provider        String   @default("groq")
  modele          String   @default("llama-3.3-70b-versatile")
  temperature     Float    @default(0.7)
  maxTokens       Int      @default(2048)
  systemPrompt    String?
  actif           Boolean  @default(true)
  quotaJournalier Int      @default(100)
  quotaMensuel    Int      @default(2000)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("sara_configs")
}

// ==============================================================================
// PAGES LÉGALES (administrables)
// ==============================================================================

model PageLegale {
  id        String   @id @default(cuid())
  slug      String   @unique // mentions-legales, cgu, confidentialite, cookies, etc.
  titreFr  String
  titreEn  String
  contenuFr String   @db.Text
  contenuEn String   @db.Text
  version  String    @default("1.0")
  publiee  Boolean   @default(false)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@map("pages_legales")
}

// ==============================================================================
// ANALYTICS ÉVÉNEMENTS
// ==============================================================================

model AnalyticsEvent {
  id         String   @id @default(cuid())
  tenantId   String?
  sessionId  String?
  userId     String?
  type       String   // PAGE_VIEW | CLICK | FORM | CONVERSION | INSTALL_PWA | etc.
  page       String?
  element    String?
  valeur     String?
  metadata   Json     @default("{}")
  ip         String?
  userAgent  String?
  pays       String?
  createdAt  DateTime @default(now())

  @@index([type])
  @@index([tenantId])
  @@index([createdAt])
  @@map("analytics_events")
}

// ==============================================================================
// EMAILS AUTOMATIQUES — TEMPLATES & LOGS
// ==============================================================================

model EmailTemplate {
  id         String   @id @default(cuid())
  slug       String   @unique // welcome, expiry-7d, expiry-3d, payment-success, etc.
  sujetFr    String
  sujetEn    String
  htmlFr     String   @db.Text
  htmlEn     String   @db.Text
  actif      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("email_templates")
}

model EmailLog {
  id         String   @id @default(cuid())
  tenantId   String?
  to         String
  sujet      String
  template   String?
  statut     String   @default("PENDING") // PENDING | SENT | FAILED | BOUNCED
  tentatives Int      @default(0)
  erreur     String?
  sentAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([tenantId])
  @@index([statut])
  @@index([createdAt])
  @@map("email_logs")
}

// ==============================================================================
// TICKETS SUPPORT
// ==============================================================================

model Ticket {
  id          String        @id @default(cuid())
  numero      String        @unique
  tenantId    String?
  userId      String?
  objet       String
  description String        @db.Text
  categorie   String?
  priorite    TicketPriorite @default(NORMALE)
  logiciel    String        @default("GESTMONEY")
  module      String?
  navigateur  String?
  appareil    String?
  statut      TicketStatut  @default(NOUVEAU)
  agentId     String?
  resolution  String?       @db.Text
  satisfaction Int?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  messages    TicketMessage[]

  @@index([tenantId])
  @@index([statut])
  @@index([createdAt])
  @@map("tickets")
}

model TicketMessage {
  id             String   @id @default(cuid())
  ticketId       String
  auteurId       String?
  contenu        String   @db.Text
  interne        Boolean  @default(false)
  pieceJointe    String?  @db.Text // fichier en data URL base64 (Cloudflare bloque le multipart)
  pieceJointeNom String?
  createdAt      DateTime @default(now())

  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@map("ticket_messages")
}

enum TicketPriorite {
  BASSE
  NORMALE
  HAUTE
  URGENTE
}

enum TicketStatut {
  NOUVEAU
  OUVERT
  EN_COURS
  ATTENTE_CLIENT
  ESCALADE
  RESOLU
  FERME
}
