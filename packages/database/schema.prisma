model Prospect {
  id              String          @id @default(cuid())
  nom             String
  prenom          String?
  entreprise      String?
  fonction        String?
  email           String?
  telephone       String?
  whatsapp        String?
  pays            String?
  secteur         String?
  tailleEntreprise String?
  logiciel        String          @default("GESTMONEY")
  besoin          String?
  budgetIndicatif String?
