// ==============================================================================
// GESTMONEY - Schéma Prisma
// Base de données: PostgreSQL
// ORM: Prisma
// ==============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "fullTextIndex"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==============================================================================
// MULTI-TENANT
// ==============================================================================

model Tenant {
  id                  String       @id @default(cuid())
  name                String
  slug                String       @unique
  domain              String?      @unique
  logo                String?
  status              TenantStatus @default(ACTIVE)
  plan                TenantPlan   @default(STARTER)
  country             String       @default("CI")
  currency            String       @default("XOF")
  timezone            String       @default("Africa/Abidjan")
  locale              String       @default("fr-CI")
  settings            Json         @default("{}")
  trialEndsAt         DateTime?
  subscriptionEndsAt  DateTime?
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  // Relations
  users               User[]
  roles               Role[]
  networks            Network[]
  agencies            Agency[]
  superAgents         SuperAgent[]
  agents              Agent[]
  territories         Territory[]
  transactions        Transaction[]
  reversals           Reversal[]
  floatAccounts       FloatAccount[]
  floatMovements      FloatMovement[]
  floatThresholds     FloatThreshold[]
  replenishmentReqs   ReplenishmentRequest[]
  cashiers            Cashier[]
  cashMovements       CashMovement[]
  vaultOperations     VaultOperation[]
  commissionPlans     CommissionPlan[]
  commissionRates     CommissionRate[]
  commissionEarnings  CommissionEarning[]
  commissionPayments  CommissionPayment[]
  customers           Customer[]
  customerAccounts    CustomerAccount[]
  loyaltyPoints       LoyaltyPoint[]
  accountCharts       AccountChart[]
  journalEntries      JournalEntry[]
  ledgers             Ledger[]
  fiscalYears         FiscalYear[]
  products            Product[]
  inventory           Inventory[]
  stockMovements      StockMovement[]
  suppliers           Supplier[]
  purchaseOrders      PurchaseOrder[]
  employees           Employee[]
  contracts           Contract[]
  payrolls            Payroll[]
  leaves              Leave[]
  auditLogs           AuditLog[]
  fraudAlerts         FraudAlert[]
  mlPredictions       MlPrediction[]
  sessions            Session[]
  kycVerifications    KycVerification[]
  integrationLogs     IntegrationLog[]
  notificationLogs    NotificationLog[]
  scheduledReports    ScheduledReport[]
  generatedReports    GeneratedReport[]

  @@map("tenants")
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  TRIAL
  EXPIRED
}

enum TenantPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

// ==============================================================================
// UTILISATEURS & AUTHENTIFICATION
// ==============================================================================

model User {
  id                  String     @id @default(cuid())
  tenantId            String
  email               String
  phone               String?
  passwordHash        String
  firstName           String
  lastName            String
  avatar              String?
  status              UserStatus @default(PENDING_VERIFICATION)
  lastLoginAt         DateTime?
  emailVerifiedAt     DateTime?
  phoneVerifiedAt     DateTime?
  twoFactorEnabled    Boolean    @default(false)
  twoFactorSecret     String?
  twoFactorVerifiedAt DateTime?
  preferredLanguage   String     @default("fr")
  timezone            String     @default("Africa/Abidjan")
  passwordChangedAt   DateTime?
  failedLoginAttempts Int        @default(0)
  lockedUntil         DateTime?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  // Relations
  tenant              Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles           UserRole[]
  sessions            Session[]
  auditLogs           AuditLog[]
  requestedReversals  Reversal[] @relation("ReversalRequestedBy")
  approvedReversals   Reversal[] @relation("ReversalApprovedBy")
  replenishmentReqs   ReplenishmentRequest[] @relation("ReplenishmentRequestedBy")
  approvedReplenishments ReplenishmentRequest[] @relation("ReplenishmentApprovedBy")
  journalEntries      JournalEntry[] @relation("JournalCreatedBy")
  postedJournals      JournalEntry[] @relation("JournalPostedBy")
  resolvedAlerts      FraudAlert[]
  closedFiscalYears   FiscalYear[]
  commissionApprovals CommissionPayment[]
  kycVerifications    KycVerification[]

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
  PASSWORD_RESET
}

model Role {
  id          String       @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isSystem    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userRoles   UserRole[]
  rolePerms   RolePermission[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  resource    String
  action      String
  description String?
  createdAt   DateTime         @default(now())

  rolePerms   RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String
  roleId    String
  grantedAt DateTime @default(now())
  grantedBy String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@map("user_roles")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  tenantId     String
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  revokedAt    DateTime?

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tenantId])
  @@map("sessions")
}

// ==============================================================================
// RÉSEAUX MOBILE MONEY
// ==============================================================================

model Network {
  id           String        @id @default(cuid())
  tenantId     String
  operatorCode String
  name         String
  country      String
  currency     String        @default("XOF")
  status       NetworkStatus @default(ACTIVE)
  apiConfig    Json?
  settings     Json          @default("{}")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agencies     Agency[]
  transactions Transaction[]
  floatAccounts FloatAccount[]
  commissionPlans CommissionPlan[]
  customerAccounts CustomerAccount[]

  @@unique([tenantId, operatorCode])
  @@index([tenantId])
  @@map("networks")
}

enum NetworkStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
}

model Agency {
  id             String       @id @default(cuid())
  tenantId       String
  networkId      String
  name           String
  code           String
  address        String
  city           String
  region         String?
  country        String       @default("CI")
  phone          String
  email          String?
  latitude       Float?
  longitude      Float?
  status         AgencyStatus @default(ACTIVE)
  managerId      String?
  openingHours   String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  tenant         Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  network        Network      @relation(fields: [networkId], references: [id])
  superAgents    SuperAgent[]
  agents         Agent[]
  transactions   Transaction[]
  floatAccounts  FloatAccount[]
  cashiers       Cashier[]
  vaultOperations VaultOperation[]

  @@unique([tenantId, networkId, code])
  @@index([tenantId])
  @@index([networkId])
  @@map("agencies")
}

enum AgencyStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model SuperAgent {
  id              String      @id @default(cuid())
  tenantId        String
  agencyId        String
  userId          String      @unique
  agentCode       String
  phoneNumber     String
  nationalId      String
  address         String
  status          AgentStatus @default(PENDING)
  commissionPlanId String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agency          Agency      @relation(fields: [agencyId], references: [id])
  commissionPlan  CommissionPlan? @relation(fields: [commissionPlanId], references: [id])
  agents          Agent[]
  commissionEarnings CommissionEarning[]
  commissionPayments CommissionPayment[]

  @@unique([tenantId, agentCode])
  @@index([tenantId])
  @@map("super_agents")
}

model Agent {
  id              String      @id @default(cuid())
  tenantId        String
  superAgentId    String?
  agencyId        String
  userId          String      @unique
  agentCode       String
  phoneNumber     String
  nationalId      String
  address         String
  status          AgentStatus @default(PENDING)
  commissionPlanId String?
  lastActivityAt  DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  superAgent      SuperAgent? @relation(fields: [superAgentId], references: [id])
  agency          Agency      @relation(fields: [agencyId], references: [id])
  commissionPlan  CommissionPlan? @relation(fields: [commissionPlanId], references: [id])
  territory       Territory?
  transactions    Transaction[]
  floatAccounts   FloatAccount[]
  commissionEarnings CommissionEarning[]
  commissionPayments CommissionPayment[]
  fraudAlerts     FraudAlert[]

  @@unique([tenantId, agentCode])
  @@index([tenantId])
  @@map("agents")
}

enum AgentStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

model Territory {
  id          String   @id @default(cuid())
  tenantId    String
  agentId     String   @unique
  name        String
  description String?
  boundaries  Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent       Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("territories")
}

// ==============================================================================
// TRANSACTIONS
// ==============================================================================

model Transaction {
  id                String            @id @default(cuid())
  tenantId          String
  reference         String
  externalReference String?
  type              TransactionType
  status            TransactionStatus @default(PENDING)
  amount            Decimal           @db.Decimal(15, 2)
  fee               Decimal           @default(0) @db.Decimal(15, 2)
  commission        Decimal           @default(0) @db.Decimal(15, 2)
  netAmount         Decimal           @db.Decimal(15, 2)
  currency          String            @default("XOF")
  operatorCode      String
  senderId          String?
  senderPhone       String?
  senderName        String?
  receiverId        String?
  receiverPhone     String?
  receiverName      String?
  agentId           String
  agencyId          String
  networkId         String
  description       String?
  metadata          Json?
  completedAt       DateTime?
  failureReason     String?
  reversalId        String?           @unique
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  tenant            Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent             Agent             @relation(fields: [agentId], references: [id])
  agency            Agency            @relation(fields: [agencyId], references: [id])
  network           Network           @relation(fields: [networkId], references: [id])
  reversal          Reversal?         @relation("ReversalOriginal", fields: [reversalId], references: [id])
  commissionEarnings CommissionEarning[]
  fraudAlerts       FraudAlert[]
  mlPredictions     MlPrediction[]

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@index([agentId])
  @@index([agencyId])
  @@index([networkId])
  @@index([status])
  @@index([createdAt])
  @@map("transactions")
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  PAYMENT
  AIRTIME_PURCHASE
  BILL_PAYMENT
  FLOAT_REPLENISHMENT
  FLOAT_WITHDRAWAL
  COMMISSION_PAYMENT
  REVERSAL
  ADJUSTMENT
}

enum TransactionStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REVERSED
  DISPUTED
  EXPIRED
}

model Reversal {
  id                    String            @id @default(cuid())
  tenantId              String
  originalTransactionId String
  reference             String
  reason                ReversalReason
  description           String?
  amount                Decimal           @db.Decimal(15, 2)
  currency              String            @default("XOF")
  status                TransactionStatus @default(PENDING)
  requestedById         String
  approvedById          String?
  approvedAt            DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  tenant                Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  requestedBy           User              @relation("ReversalRequestedBy", fields: [requestedById], references: [id])
  approvedBy            User?             @relation("ReversalApprovedBy", fields: [approvedById], references: [id])
  transaction           Transaction?      @relation("ReversalOriginal")

  @@unique([tenantId, reference])
  @@index([tenantId])
  @@map("reversals")
}

enum ReversalReason {
  CUSTOMER_REQUEST
  TECHNICAL_ERROR
  FRAUD_DETECTED
  DUPLICATE_TRANSACTION
  INSUFFICIENT_FUNDS
  OPERATOR_ERROR
  COMPLIANCE
}

// ==============================================================================
// GESTION DU FLOAT (LIQUIDITÉ)
// ==============================================================================

model FloatAccount {
  id               String    @id @default(cuid())
  tenantId         String
  agentId          String?
  agencyId         String?
  networkId        String
  accountNumber    String
  balance          Decimal   @default(0) @db.Decimal(15, 2)
  reservedBalance  Decimal   @default(0) @db.Decimal(15, 2)
  currency         String    @default("XOF")
  minimumBalance   Decimal   @default(0) @db.Decimal(15, 2)
  maximumBalance   Decimal   @db.Decimal(15, 2)
  isActive         Boolean   @default(true)
  lastMovementAt   DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent            Agent?    @relation(fields: [agentId], references: [id])
  agency           Agency?   @relation(fields: [agencyId], references: [id])
  network          Network   @relation(fields: [networkId], references: [id])
  movements        FloatMovement[]
  thresholds       FloatThreshold[]
  replenishments   ReplenishmentRequest[]

  @@unique([tenantId, accountNumber])
  @@index([tenantId])
  @@map("float_accounts")
}

model FloatMovement {
  id              String              @id @default(cuid())
  tenantId        String
  floatAccountId  String
  transactionId   String?
  type            FloatMovementType
  amount          Decimal             @db.Decimal(15, 2)
  balanceBefore   Decimal             @db.Decimal(15, 2)
  balanceAfter    Decimal             @db.Decimal(15, 2)
  currency        String              @default("XOF")
  description     String
  reference       String
  performedById   String
  createdAt       DateTime            @default(now())

  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  floatAccount    FloatAccount        @relation(fields: [floatAccountId], references: [id])

  @@index([tenantId])
  @@index([floatAccountId])
  @@map("float_movements")
}

enum FloatMovementType {
  CREDIT
  DEBIT
}

model FloatThreshold {
  id                    String       @id @default(cuid())
  tenantId              String
  floatAccountId        String
  warningLevel          Decimal      @db.Decimal(15, 2)
  criticalLevel         Decimal      @db.Decimal(15, 2)
  autoReplenishEnabled  Boolean      @default(false)
  autoReplenishAmount   Decimal?     @db.Decimal(15, 2)
  notifyEmails          String[]
  notifyPhones          String[]
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt

  tenant                Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  floatAccount          FloatAccount @relation(fields: [floatAccountId], references: [id], onDelete: Cascade)

  @@unique([tenantId, floatAccountId])
  @@index([tenantId])
  @@map("float_thresholds")
}

model ReplenishmentRequest {
  id               String               @id @default(cuid())
  tenantId         String
  floatAccountId   String
  requestedById    String
  requestedAmount  Decimal              @db.Decimal(15, 2)
  approvedAmount   Decimal?             @db.Decimal(15, 2)
  currency         String               @default("XOF")
  status           ReplenishmentStatus  @default(PENDING)
  reason           String?
  rejectionReason  String?
  approvedById     String?
  approvedAt       DateTime?
  paymentReference String?
  completedAt      DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  tenant           Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  floatAccount     FloatAccount         @relation(fields: [floatAccountId], references: [id])
  requestedBy      User                 @relation("ReplenishmentRequestedBy", fields: [requestedById], references: [id])
  approvedBy       User?                @relation("ReplenishmentApprovedBy", fields: [approvedById], references: [id])

  @@index([tenantId])
  @@map("replenishment_requests")
}

enum ReplenishmentStatus {
  PENDING
  APPROVED
  REJECTED
  PROCESSING
  COMPLETED
  CANCELLED
}

// ==============================================================================
// CAISSE & COFFRE
// ==============================================================================

model Cashier {
  id         String   @id @default(cuid())
  tenantId   String
  agencyId   String
  userId     String   @unique
  code       String
  isOpen     Boolean  @default(false)
  openedAt   DateTime?
  closedAt   DateTime?
  openingBalance Decimal @default(0) @db.Decimal(15, 2)
  closingBalance Decimal? @db.Decimal(15, 2)
  currency   String   @default("XOF")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agency     Agency   @relation(fields: [agencyId], references: [id])
  movements  CashMovement[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@map("cashiers")
}

model CashMovement {
  id          String            @id @default(cuid())
  tenantId    String
  cashierId   String
  type        FloatMovementType
  amount      Decimal           @db.Decimal(15, 2)
  balanceBefore Decimal         @db.Decimal(15, 2)
  balanceAfter  Decimal         @db.Decimal(15, 2)
  currency    String            @default("XOF")
  description String
  reference   String
  performedById String
  createdAt   DateTime          @default(now())

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cashier     Cashier           @relation(fields: [cashierId], references: [id])

  @@index([tenantId])
  @@index([cashierId])
  @@map("cash_movements")
}

model VaultOperation {
  id          String              @id @default(cuid())
  tenantId    String
  agencyId    String
  type        VaultOperationType
  amount      Decimal             @db.Decimal(15, 2)
  balanceBefore Decimal           @db.Decimal(15, 2)
  balanceAfter  Decimal           @db.Decimal(15, 2)
  currency    String              @default("XOF")
  description String
  reference   String
  performedById String
  approvedById  String?
  approvedAt  DateTime?
  createdAt   DateTime            @default(now())

  tenant      Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agency      Agency              @relation(fields: [agencyId], references: [id])

  @@index([tenantId])
  @@index([agencyId])
  @@map("vault_operations")
}

enum VaultOperationType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER_IN
  TRANSFER_OUT
  ADJUSTMENT
}

// ==============================================================================
// COMMISSIONS
// ==============================================================================

model CommissionPlan {
  id            String          @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  networkId     String
  basis         CommissionBasis
  isActive      Boolean         @default(true)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  tenant        Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  network       Network         @relation(fields: [networkId], references: [id])
  rates         CommissionRate[]
  superAgents   SuperAgent[]
  agents        Agent[]
  earnings      CommissionEarning[]

  @@unique([tenantId, name, networkId])
  @@index([tenantId])
  @@map("commission_plans")
}

enum CommissionBasis {
  PERCENTAGE
  FIXED
  TIERED
}

model CommissionRate {
  id               String         @id @default(cuid())
  tenantId         String
  commissionPlanId String
  transactionType  String
  minAmount        Decimal?       @db.Decimal(15, 2)
  maxAmount        Decimal?       @db.Decimal(15, 2)
  rate             Decimal        @db.Decimal(8, 4)
  fixedAmount      Decimal?       @db.Decimal(15, 2)
  agentShare       Decimal        @default(70) @db.Decimal(5, 2)
  superAgentShare  Decimal        @default(10) @db.Decimal(5, 2)
  agencyShare      Decimal        @default(15) @db.Decimal(5, 2)
  networkShare     Decimal        @default(5) @db.Decimal(5, 2)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  commissionPlan   CommissionPlan @relation(fields: [commissionPlanId], references: [id], onDelete: Cascade)
  earnings         CommissionEarning[]

  @@index([tenantId])
  @@index([commissionPlanId])
  @@map("commission_rates")
}

model CommissionEarning {
  id               String         @id @default(cuid())
  tenantId         String
  transactionId    String
  agentId          String?
  superAgentId     String?
  agencyId         String?
  commissionPlanId String
  commissionRateId String
  grossAmount      Decimal        @db.Decimal(15, 2)
  agentAmount      Decimal        @db.Decimal(15, 2)
  superAgentAmount Decimal        @db.Decimal(15, 2)
  agencyAmount     Decimal        @db.Decimal(15, 2)
  networkAmount    Decimal        @db.Decimal(15, 2)
  currency         String         @default("XOF")
  periodMonth      Int
  periodYear       Int
  createdAt        DateTime       @default(now())

  tenant           Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transaction      Transaction    @relation(fields: [transactionId], references: [id])
  agent            Agent?         @relation(fields: [agentId], references: [id])
  superAgent       SuperAgent?    @relation(fields: [superAgentId], references: [id])
  commissionPlan   CommissionPlan @relation(fields: [commissionPlanId], references: [id])
  commissionRate   CommissionRate @relation(fields: [commissionRateId], references: [id])

  @@index([tenantId])
  @@index([transactionId])
  @@index([periodMonth, periodYear])
  @@map("commission_earnings")
}

model CommissionPayment {
  id            String                  @id @default(cuid())
  tenantId      String
  agentId       String?
  superAgentId  String?
  agencyId      String?
  periodMonth   Int
  periodYear    Int
  totalEarnings Decimal                 @db.Decimal(15, 2)
  deductions    Decimal                 @default(0) @db.Decimal(15, 2)
  netAmount     Decimal                 @db.Decimal(15, 2)
  currency      String                  @default("XOF")
  status        CommissionPaymentStatus @default(PENDING)
  paymentMethod String?
  paymentReference String?
  paidAt        DateTime?
  approvedById  String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  tenant        Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  agent         Agent?                  @relation(fields: [agentId], references: [id])
  superAgent    SuperAgent?             @relation(fields: [superAgentId], references: [id])
  approvedBy    User?                   @relation(fields: [approvedById], references: [id])

  @@index([tenantId])
  @@index([periodMonth, periodYear])
  @@map("commission_payments")
}

enum CommissionPaymentStatus {
  PENDING
  CALCULATED
  APPROVED
  PAID
  CANCELLED
}

// ==============================================================================
// CLIENTS & FIDÉLITÉ
// ==============================================================================

model Customer {
  id                String         @id @default(cuid())
  tenantId          String
  phoneNumber       String
  firstName         String?
  lastName          String?
  email             String?
  nationalId        String?
  dateOfBirth       DateTime?
  address           String?
  city              String?
  country           String         @default("CI")
