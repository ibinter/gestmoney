  employee      Employee      @relation(fields: [employeeId], references: [id])

  @@unique([tenantId, employeeId, periodMonth, periodYear])
  @@index([tenantId])
  @@map("payrolls")
}

enum PayrollStatus {
  DRAFT
  VALIDATED
  PAID
  CANCELLED
}

model Leave {
  id           String      @id @default(cuid())
  tenantId     String
  employeeId   String
  type         LeaveType
  startDate    DateTime
  endDate      DateTime
