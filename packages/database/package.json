{
  "name": "@gestmoney/database",
  "version": "1.0.0",
  "private": true,
  "description": "Schémas Prisma et migrations GESTMONEY",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
