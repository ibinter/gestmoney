# Variables d'environnement du service IA GESTMONEY
# Copiez ce fichier en .env et adaptez les valeurs

# Base de données PostgreSQL (partagée avec le backend NestJS)
DATABASE_URL=postgresql://gestmoney:gestmoney@localhost:5432/gestmoney

# Clé secrète pour la communication inter-services
API_SECRET=change-me-in-production

# URL du backend NestJS pour les callbacks
NESTJS_URL=http://localhost:3000

# Répertoire de sauvegarde des modèles ML (doit être persistant en production)
MODEL_PATH=/app/models_saved

# Seuil de score fraude pour créer une alerte en base (0-100)
FRAUD_ALERT_THRESHOLD=60

# Seuil de float minimum en XOF avant alerte de rechargement
FLOAT_LOW_THRESHOLD=50000

# Écart de caisse maximum toléré (XOF)
MAX_CASH_DISCREPANCY=10000

# Environnement : development | staging | production
ENVIRONMENT=development
DEBUG=true
PORT=8001
