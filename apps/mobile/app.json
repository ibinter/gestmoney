{
  "expo": {
    "name": "GESTMONEY",
    "slug": "gestmoney",
    "version": "1.0.0",
    "scheme": "gestmoney",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5B800"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.ibigsoft.gestmoney"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5B800"
      },
      "package": "com.ibigsoft.gestmoney",
      "permissions": [
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-sqlite",
        {
          "enableFTS": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "gestmoney-ibigsoft"
      }
    }
  }
}
